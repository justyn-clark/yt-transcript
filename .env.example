# yt-transcript Configuration
# Copy to .env and adjust values as needed.

# Postgres connection (asyncpg)
YT_TRANSCRIPT_DATABASE_ENABLED=true
YT_TRANSCRIPT_DATABASE_URL=postgresql+asyncpg://localhost:5432/yt_transcript
YT_TRANSCRIPT_DATABASE_URL_SYNC=postgresql://localhost:5432/yt_transcript

# Markdown note export directory (optional - leave unset to disable note export)
# Point this at any directory. Works well as an Obsidian vault root.
# YT_TRANSCRIPT_NOTES_DIR=/path/to/your/notes
YT_TRANSCRIPT_NOTES_SUBDIR=Transcripts/YouTube

# ASR worker (shared-filesystem mode - see README for topology requirements)
YT_TRANSCRIPT_ASR_WORKER_URL=http://localhost:8787
YT_TRANSCRIPT_ASR_WORKER_TIMEOUT=300

# Temp directory for downloads
YT_TRANSCRIPT_TMP_DIR=/tmp/yt-transcript

# API server binding
YT_TRANSCRIPT_API_HOST=127.0.0.1
YT_TRANSCRIPT_API_PORT=8420
