# JCN Transcript Service Configuration
# Copy to .env and adjust values as needed.

# Postgres connection (asyncpg)
JCN_TRANSCRIPT_DATABASE_URL=postgresql+asyncpg://justin@localhost:5432/jcn_transcript
JCN_TRANSCRIPT_DATABASE_URL_SYNC=postgresql://justin@localhost:5432/jcn_transcript

# Obsidian vault root
JCN_TRANSCRIPT_VAULT_PATH=/Users/justin/Documents/Justyn Clark Network/REPOS/jcn-obsidian-vault
JCN_TRANSCRIPT_VAULT_TRANSCRIPT_DIR=Inbox/Transcripts/YouTube

# Mac Studio ASR worker
JCN_TRANSCRIPT_ASR_WORKER_URL=http://studio.local:8787
JCN_TRANSCRIPT_ASR_WORKER_TIMEOUT=300

# Temp directory for downloads
JCN_TRANSCRIPT_TMP_DIR=/tmp/jcn-transcript

# API server binding
JCN_TRANSCRIPT_API_HOST=127.0.0.1
JCN_TRANSCRIPT_API_PORT=8420

# Embeddings (disabled by default until model is confirmed)
JCN_TRANSCRIPT_EMBEDDINGS_ENABLED=false
JCN_TRANSCRIPT_EMBEDDING_MODEL=
JCN_TRANSCRIPT_EMBEDDING_DIMENSION=0
